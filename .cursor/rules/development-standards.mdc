    setChartLayout(prev => prev === 'vertical' ? 'horizontal' : 'vertical');
  }, []);
  
  // Effect cleanup
  useEffect(() => {
    // Setup logic
    return () => {
      // Cleanup logic
    };
  }, []);
  
  return (
    <div className="chart-container">
      {/* Component JSX */}
    </div>
  );
}
```

### State Management Patterns
```typescript
// Custom hooks for complex state logic
function useChartData(initialData: ChartData) {
  const [data, setData] = useState(initialData);
  const [isLoading, setIsLoading] = useState(false);
  
  const updateData = useCallback(async (newData: ChartData) => {
    setIsLoading(true);
    try {
      // Process data
      setData(newData);
    } finally {
      setIsLoading(false);
    }
  }, []);
  
  return { data, isLoading, updateData };
}
```

## 🔒 Security Standards

### Input Validation
```python
def validate_sql_safety(query: str, config: WorkflowConfig) -> bool:
    """Validate SQL query against security rules."""
    # Check forbidden patterns
    forbidden = config.sql_safety.forbidden_patterns
    query_upper = query.upper()
    
    for pattern in forbidden:
        if pattern.upper() in query_upper:
            raise SecurityError(f"Forbidden SQL pattern detected: {pattern}")
    
    # Check query length
    if len(query) > config.sql_safety.max_sql_length:
        raise SecurityError("SQL query exceeds maximum allowed length")
    
    return True

def validate_input_content(question: str, config: WorkflowConfig) -> bool:
    """Validate user input against injection attacks."""
    blocked = config.input_validation.blocked_substrings
    
    for blocked_content in blocked:
        if blocked_content.lower() in question.lower():
            raise SecurityError(f"Blocked content detected in input: {blocked_content}")
    
    return True
```

### Sensitive Data Handling
```python
# Never log sensitive data
def log_connection_attempt(connection_string: str, success: bool):
    """Log connection attempt without exposing credentials."""
    # Extract only non-sensitive parts
    parsed = urlparse(connection_string)
    safe_connection = f"{parsed.scheme}://{parsed.hostname}:{parsed.port}"
    
    logger.info(f"Database connection {'succeeded' if success else 'failed'}: {safe_connection}")

# Use environment variables for secrets
def get_api_key(provider: str) -> str:
    """Get API key from environment variable."""
    env_var = f"{provider.upper()}_API_KEY"
    api_key = os.getenv(env_var)
    
    if not api_key:
        raise ConfigurationError(
            f"Missing required environment variable: {env_var}. "
            f"Please set it with: export {env_var}='your-api-key'"
        )
    
    return api_key
```

## 📋 Code Review Checklist

### Before Submitting Code
1. ✅ **Type hints added** - All functions have proper type annotations
2. ✅ **Documentation complete** - Docstrings for all public functions
3. ✅ **Error handling** - Appropriate exceptions and logging
4. ✅ **Tests written** - Unit and integration tests cover new code
5. ✅ **Security reviewed** - Input validation and sensitive data protection
6. ✅ **Performance considered** - No obvious performance bottlenecks
7. ✅ **Configuration updated** - New features have config options
8. ✅ **Examples updated** - Relevant example configurations updated

### Code Quality Gates
1. **No hardcoded values** - Use configuration or constants
2. **No magic numbers** - Named constants for all numeric values
3. **Consistent naming** - Follow established naming conventions
4. **Single responsibility** - Each function/class has one clear purpose
5. **Open/closed principle** - Easy to extend, hard to modify
6. **Dependency injection** - Avoid tight coupling between components