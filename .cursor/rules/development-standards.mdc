## 🗄️ Database Integration Standards

### Strategy Implementation Requirements
```python
from abc import ABC, abstractmethod

class DatabaseConnectionStrategy(ABC):
    """Base strategy for database-specific operations."""
    
    @abstractmethod
    def authenticate(self, config: Any) -> bool:
        """Authenticate with the database using provided configuration."""
        pass
    
    @abstractmethod
    def test_connection(self, db: Any, config: Any) -> bool:
        """Test database connection and return success status."""
        pass
    
    @abstractmethod
    def enhance_schema(self, schema: str, config: Any) -> str:
        """Enhance schema with database-specific information."""
        pass

# Concrete implementation example
class BigQueryStrategy(DatabaseConnectionStrategy):
    def authenticate(self, config: Any) -> bool:
        """BigQuery-specific authentication logic."""
        if config.database.bigquery_gcloud_cli_auth:
            return self._authenticate_gcloud_cli()
        else:
            return self._authenticate_service_account(config)
```

### Schema Decorator Pattern
```python
class SchemaDecorator(ABC):
    """Base class for schema enhancement decorators."""
    
    @abstractmethod
    def enhance_schema(self, schema: str, config: Any) -> str:
        """Enhance the provided schema and return enhanced version."""
        pass

# Fluent builder pattern for decorator chains
class SchemaDecoratorBuilder:
    def __init__(self, schema: str):
        self._schema = schema
        self._decorators: List[SchemaDecorator] = []
    
    def with_cross_project_enhancement(self) -> 'SchemaDecoratorBuilder':
        self._decorators.append(CrossProjectSchemaDecorator())
        return self
    
    def with_hybrid_descriptions(self) -> 'SchemaDecoratorBuilder':
        self._decorators.append(HybridDescriptionDecorator())
        return self
    
    def build(self) -> SchemaProvider:
        return ChainedSchemaProvider(self._schema, self._decorators)
```

## 🤖 LLM Integration Standards

### Provider-Agnostic Design
```python
class LLMManager:
    """Manage interactions with various LLM providers."""
    
    def __init__(self, config: LLMConfig):
        self.llm = self._create_llm(config)
        self.config = config
    
    def _create_llm(self, config: LLMConfig):
        """Factory method to create provider-specific LLM instances."""
        if config.provider == "openai":
            return self._create_openai_llm(config)
        elif config.provider == "azure_openai":
            return self._create_azure_openai_llm(config)
        # ... other providers
        else:
            raise ValueError(f"Unsupported LLM provider: {config.provider}")
```

### Prompt Management
```python
# Template-based prompt system
def create_prompt_from_config(self, prompt_name: str, **kwargs) -> str:
    """Create prompt from configuration template with variable substitution."""
    prompt_config = self.config.get_prompt(prompt_name)
    
    # Validate required variables
    required_vars = self._extract_template_vars(prompt_config['human'])
    missing_vars = required_vars - set(kwargs.keys())
    if missing_vars:
        raise ValueError(f"Missing required prompt variables: {missing_vars}")
    
    # Format prompt with provided variables
    return prompt_config['human'].format(**kwargs)
```

## 📊 Configuration Management Standards

### Configuration Dataclasses
```python
@dataclass
class NewFeatureConfig:
    """Configuration for new feature functionality."""
    enabled: bool = True
    advanced_mode: bool = False
    custom_settings: Dict[str, Any] = field(default_factory=dict)
    
    def __post_init__(self):
        """Validate configuration after initialization."""
        if self.enabled and not self.custom_settings:
            self.custom_settings = {"default_setting": "default_value"}

# Integration with main config
@dataclass  
class DatabaseConfig:
    connection_string: str
    # ... existing fields
    new_feature: NewFeatureConfig = field(default_factory=NewFeatureConfig)
```

### Environment Variable Support
```python
def _substitute_env_vars(self, value: str) -> str:
    """Substitute environment variables in configuration values."""
    import os
    import re
    
    # Support ${VAR} and ${VAR:-default} syntax
    pattern = r'\$\{([^}]+)\}'
    
    def replace_var(match):
        var_expr = match.group(1)
        if ':-' in var_expr:
            var_name, default = var_expr.split(':-', 1)
            return os.getenv(var_name, default)
        else:
            return os.getenv(var_expr, match.group(0))
    
    return re.sub(pattern, replace_var, value)
```

